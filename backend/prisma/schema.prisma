generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
  TRIAL
}

enum UserRole {
  SUPERADMIN
  ADMIN
  SOPORTE
  CLIENTE
}

enum SessionLimitPolicy {
  BLOCK_NEW
  REPLACE_OLDEST
}

enum ChannelStatus {
  ACTIVE
  SCHEDULED
  MAINTENANCE
  INACTIVE
}

enum StreamProtocol {
  HLS
  DASH
  HLS_DASH
}

enum ChannelHealthStatus {
  HEALTHY
  DEGRADED
  OFFLINE
  MAINTENANCE
}

// ─── Models ──────────────────────────────────────────────

model Customer {
  id                 String     @id @default(uuid())
  nombre             String
  firstName          String?
  lastName           String?
  email              String?    @unique
  ispEmail           String?
  telefono           String?
  idNumber           String?    @unique // Cédula de identidad
  address            String?    // Dirección
  passwordHash       String?
  role               UserRole   @default(CLIENTE)
  status             UserStatus @default(PENDING)
  mustChangePassword Boolean    @default(false)
  mfaEnabled         Boolean    @default(false)
  isLocked           Boolean    @default(false)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  isCmsUser          Boolean    @default(false)
  isSubscriber       Boolean    @default(true)
  isAccountActivated Boolean    @default(false)
  permissions        String[]   @default([])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  contracts Contract[]
  sessions  Session[]

  @@map("customers")
}

model Contract {
  id                  String             @id @default(uuid())
  customerId          String
  contractNumber      String             @unique @db.VarChar(20)
  planName            String             @default("LUKI PLAY")
  planId              String?
  ispPlanName         String?
  maxDevices          Int                @default(2)
  maxConcurrentStreams Int               @default(1)
  sessionDurationDays Int                @default(30)
  sessionLimitPolicy  SessionLimitPolicy @default(BLOCK_NEW)
  fechaInicio         DateTime?
  fechaFin            DateTime?
  lastSyncedAt        DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  customer        Customer         @relation(fields: [customerId], references: [id])
  sessions        Session[]
  viewingProfiles ViewingProfile[]
  devices         Device[]

  @@index([customerId])
  @@map("contracts")
}

model ViewingProfile {
  id                     String   @id @default(uuid())
  contractId             String
  displayName            String
  avatarUrl              String?
  preferredLang          String   @default("es")
  parentalControlEnabled Boolean  @default(false)
  parentalControlPin     String?
  contentPreferences     Json     @default("{}")
  isDefault              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@map("viewing_profiles")
}

model Session {
  id           String    @id @default(uuid())
  contractId   String?
  customerId   String?
  deviceId     String
  audience     String    @default("app")
  refreshToken String?   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  contract Contract? @relation(fields: [contractId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([contractId])
  @@index([customerId])
  @@map("sessions")
}

model Device {
  id                String    @id @default(uuid())
  contractId        String
  deviceName        String?
  deviceType        String?
  deviceFingerprint String    @unique
  isActive          Boolean   @default(true)
  lastUsedAt        DateTime?
  createdAt         DateTime  @default(now())

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@map("devices")
}

model Plan {
  id                  String   @id @default(uuid())
  nombre              String   @default("LUKI PLAY")
  descripcion         String   @default("Streaming incluido con tu servicio de internet Luki")
  activo              Boolean  @default(true)
  maxDevices          Int      @default(2)
  maxConcurrentStreams Int     @default(1)
  maxProfiles         Int      @default(3)
  videoQuality        String   @default("HD")
  allowDownloads      Boolean  @default(false)
  allowCasting        Boolean  @default(true)
  hasAds              Boolean  @default(true)
  entitlements        Json     @default("[\"live-tv\", \"vod-basic\", \"sports\"]")
  allowedComponentIds Json     @default("[]")
  allowedCategoryIds  Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("plans")
}

model SyncLog {
  id                 String    @id @default(uuid())
  syncType           String
  startedAt          DateTime
  completedAt        DateTime?
  customersCreated   Int       @default(0)
  contractsCreated   Int       @default(0)
  contractsUpdated   Int       @default(0)
  contractsSuspended Int       @default(0)
  errors             Int       @default(0)
  errorDetails       Json?
  createdAt          DateTime  @default(now())

  @@map("sync_log")
}

model Category {
  id            String    @id @default(uuid())
  nombre        String    @unique
  descripcion   String    @default("")
  icono         String    @default("")
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  channels Channel[]

  @@map("categories")
}

model Channel {
  id                      String              @id @default(uuid())
  nombre                  String              @unique
  slug                    String              @unique

  // Stream URLs
  streamUrl               String
  backupUrl               String?

  // Metadata
  logoUrl                 String?
  categoryId              String
  category                Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  epgSourceId             String?

  // Status & Status Management
  status                  ChannelStatus       @default(ACTIVE)
  isLive                  Boolean             @default(false)
  healthStatus            ChannelHealthStatus @default(OFFLINE)
  uptimePercent           Float               @default(0)
  lastHealthCheckAt       DateTime?

  // Stream Configuration
  streamProtocol          StreamProtocol      @default(HLS)
  resolution              String              @default("1080p")
  bitrateKbps             Int                 @default(5000)
  isDrmProtected          Boolean             @default(false)

  // Geographic & Access Control
  geoRestriction          String?
  sortOrder               Int                 @default(99)
  planIds                 String[]            @default([])
  requiereControlParental Boolean             @default(false)

  // Analytics & Monitoring
  viewerCount             Int                 @default(0)

  // Audit
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  deletedAt               DateTime?

  @@index([categoryId])
  @@index([status])
  @@index([isLive])
  @@map("channels")
}

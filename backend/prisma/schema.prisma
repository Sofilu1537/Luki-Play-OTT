generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
  TRIAL
}

enum UserRole {
  SUPERADMIN
  ADMIN
  SOPORTE
  CLIENTE
}

enum SessionLimitPolicy {
  BLOCK_NEW
  REPLACE_OLDEST
}

enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
  SMART_TV
  UNKNOWN
}

enum RegistrationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChannelStatus {
  ACTIVE
  SCHEDULED
  MAINTENANCE
  INACTIVE
}

enum StreamProtocol {
  HLS
  DASH
  HLS_DASH
}

enum ChannelHealthStatus {
  HEALTHY
  DEGRADED
  OFFLINE
  MAINTENANCE
}

enum SliderAction {
  NONE
  PLAY_CHANNEL
  NAVIGATE_CATEGORY
  OPEN_URL
  SHOW_PLAN
}

enum SubscriptionStatus {
  ACTIVE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationType {
  SUBSCRIPTION_REMINDER
  SUBSCRIPTION_EXPIRED
  SUBSCRIPTION_SUSPENDED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
}

// ─── Models ──────────────────────────────────────────────

model CmsRole {
  id          String   @id @default(uuid())
  key         UserRole @unique
  permissions String[] @default([])
  updatedAt   DateTime @updatedAt

  @@map("cms_roles")
}

model Customer {
  id                 String     @id @default(uuid())
  nombre             String
  firstName          String?
  lastName           String?
  email              String?    @unique
  ispEmail           String?
  telefono           String?
  idNumber           String?    @unique // Cédula de identidad
  address            String?    // Dirección
  passwordHash       String?
  role               UserRole   @default(CLIENTE)
  status             UserStatus @default(PENDING)
  mustChangePassword Boolean    @default(false)
  mfaEnabled         Boolean    @default(false)
  isLocked           Boolean    @default(false)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  isCmsUser          Boolean    @default(false)
  isSubscriber       Boolean    @default(true)
  isAccountActivated Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  contracts       Contract[]
  sessions        Session[]
  activationCodes ActivationCode[]
  subscriptions   Subscription[]
  payments        Payment[]
  notifications   Notification[]
  favorites       ChannelFavorite[]
  activeStreams    ActiveStream[]
  devices         Device[]

  @@map("customers")
}

model Contract {
  id                  String             @id @default(uuid())
  customerId          String
  contractNumber      String             @unique @db.VarChar(20)
  planName            String             @default("LUKI PLAY")
  planId              String?
  ispPlanName         String?
  maxDevices          Int                @default(2)
  maxConcurrentStreams Int               @default(1)
  sessionDurationDays Int                @default(30)
  sessionLimitPolicy  SessionLimitPolicy @default(BLOCK_NEW)
  fechaInicio         DateTime?
  fechaFin            DateTime?
  lastSyncedAt        DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  customer        Customer         @relation(fields: [customerId], references: [id])
  sessions        Session[]
  viewingProfiles ViewingProfile[]
  devices         Device[]

  @@index([customerId])
  @@map("contracts")
}

model ViewingProfile {
  id                     String   @id @default(uuid())
  contractId             String
  displayName            String
  avatarUrl              String?
  preferredLang          String   @default("es")
  parentalControlEnabled Boolean  @default(false)
  parentalControlPin     String?
  contentPreferences     Json     @default("{}")
  isDefault              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@map("viewing_profiles")
}

model Session {
  id           String    @id @default(uuid())
  contractId   String?
  customerId   String?
  deviceId     String
  audience     String    @default("app")
  refreshToken String?   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  contract Contract? @relation(fields: [contractId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([contractId])
  @@index([customerId])
  @@map("sessions")
}

model ActiveStream {
  id            String   @id @default(uuid())
  customerId    String
  contractId    String?
  deviceId      String
  channelId     String
  lastHeartbeat DateTime @default(now())
  startedAt     DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("active_streams")
}

model Device {
  id                String     @id @default(uuid())
  customerId        String
  contractId        String?
  deviceFingerprint String
  nombre            String?
  tipo              DeviceType @default(UNKNOWN)
  os                String?
  browser           String?
  modelo            String?
  ipAddress         String?
  isActive          Boolean    @default(true)
  lastSeenAt        DateTime?
  registeredAt      DateTime   @default(now())
  deletedAt         DateTime?

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id])

  @@unique([customerId, deviceFingerprint])
  @@index([customerId])
  @@index([contractId])
  @@map("devices")
}

model Plan {
  id                  String   @id @default(uuid())
  nombre              String   @default("LUKI PLAY")
  descripcion         String   @default("Streaming incluido con tu servicio de luki Internet")
  grupoUsuarios       String   @default("ISP_BUNDLE")
  precio              Float    @default(0)
  moneda              String   @default("USD")
  duracionDias        Int      @default(30)
  activo              Boolean  @default(true)
  maxDevices          Int      @default(3)
  maxConcurrentStreams Int     @default(2)
  maxProfiles         Int      @default(3)
  videoQuality        String   @default("HD")
  allowDownloads      Boolean  @default(false)
  allowCasting        Boolean  @default(true)
  hasAds              Boolean  @default(true)
  trialDays           Int      @default(0)
  gracePeriodDays     Int      @default(0)
  entitlements        Json     @default("[\"live-tv\", \"vod-basic\", \"sports\"]")
  allowedComponentIds Json     @default("[]")
  allowedCategoryIds  Json     @default("[]")
  allowedChannelIds   Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model ActivationCode {
  id          String    @id @default(uuid())
  customerId  String
  code        String    // "A1B2C3" — alfanumérico 6 chars, en texto plano (corta vida)
  generatedBy String?   // NULL = autoservicio, userId = generado por soporte CMS
  sentToEmail String?   // Email al que se envió el código (NULL si fue por soporte)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([code])
  @@index([customerId])
  @@map("activation_codes")
}

model RegistrationRequest {
  id          String                    @id @default(uuid())
  nombres     String
  apellidos   String
  idNumber    String
  telefono    String
  email       String?
  direccion   String?
  status      RegistrationRequestStatus @default(PENDING)
  reviewedBy  String?   // ID del usuario CMS que aprobó/rechazó
  reviewedAt  DateTime?
  reviewNotes String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([status])
  @@index([idNumber])
  @@map("registration_requests")
}

model SyncLog {
  id                 String    @id @default(uuid())
  syncType           String
  startedAt          DateTime
  completedAt        DateTime?
  customersCreated   Int       @default(0)
  contractsCreated   Int       @default(0)
  contractsUpdated   Int       @default(0)
  contractsSuspended Int       @default(0)
  errors             Int       @default(0)
  errorDetails       Json?
  createdAt          DateTime  @default(now())

  @@map("sync_log")
}

model Category {
  id            String    @id @default(uuid())
  nombre        String    @unique
  slug          String?   @unique
  descripcion   String    @default("")
  icono         String    @default("")
  accentColor   String    @default("#FFB800")
  displayOrder  Int       @default(99)
  activo        Boolean   @default(true)
  esContenidoAdulto Boolean @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  channels            Channel[]
  channelCategories   ChannelCategory[]
  componentCategories ComponentCategory[]

  @@index([activo])
  @@index([displayOrder])
  @@map("categories")
}

model ChannelCategory {
  channelId  String
  categoryId String
  assignedAt DateTime @default(now())

  channel  Channel  @relation(fields: [channelId],  references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([channelId, categoryId])
  @@index([channelId])
  @@index([categoryId])
  @@map("channel_categories")
}

model Channel {
  id                      String              @id @default(uuid())
  nombre                  String              @unique
  slug                    String              @unique

  // Stream URLs
  streamUrl               String
  backupUrl               String?

  // Metadata
  logoUrl                 String?
  categoryId              String
  category                Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  epgSourceId             String?

  // Status & Status Management
  status                  ChannelStatus       @default(ACTIVE)
  isLive                  Boolean             @default(false)
  healthStatus            ChannelHealthStatus @default(OFFLINE)
  uptimePercent           Float               @default(0)
  lastHealthCheckAt       DateTime?

  // Stream Configuration
  streamProtocol          StreamProtocol      @default(HLS)
  resolution              String              @default("1080p")
  bitrateKbps             Int                 @default(5000)
  isDrmProtected          Boolean             @default(false)

  // Geographic & Access Control
  geoRestriction          String?
  sortOrder               Int                 @default(99)
  planIds                 String[]            @default([])
  requiereControlParental Boolean             @default(false)

  // Analytics & Monitoring
  viewerCount             Int                 @default(0)

  // Audit
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  deletedAt               DateTime?

  channelCategories ChannelCategory[]
  favorites         ChannelFavorite[]

  @@index([categoryId])
  @@index([status])
  @@index([isLive])
  @@map("channels")
}

model ChannelFavorite {
  id         String   @id @default(uuid())
  customerId String
  channelId  String
  deviceId   String
  profileId  String   @default("__default__")
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([customerId, channelId, deviceId, profileId])
  @@index([customerId, deviceId, profileId])
  @@map("channel_favorites")
}

model Component {
  id          String   @id
  nombre      String   @unique
  descripcion String   @default("")
  icono       String   @default("")
  tipo        String
  activo      Boolean  @default(true)
  orden       Int      @default(99)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  componentCategories ComponentCategory[]

  @@index([activo])
  @@index([orden])
  @@map("components")
}

model Slider {
  id            String       @id @default(uuid())
  titulo        String
  subtitulo     String?
  imagen        String
  imagenMobile  String?
  orden         Int          @default(0)
  activo        Boolean      @default(true)
  actionType    SliderAction @default(NONE)
  actionValue   String?
  startDate     DateTime?
  endDate       DateTime?
  planIds       String[]     @default([])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([activo, orden])
  @@map("sliders")
}

model ComponentCategory {
  componentId String
  categoryId  String
  assignedAt  DateTime @default(now())

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId],  references: [id], onDelete: Cascade)

  @@id([componentId, categoryId])
  @@index([componentId])
  @@index([categoryId])
  @@map("component_categories")
}

// ─── Subscription System ─────────────────────────────────

model Subscription {
  id                 String             @id @default(uuid())
  customerId         String
  planId             String
  startDate          DateTime
  expirationDate     DateTime
  gracePeriodEnd     DateTime?          // null when plan.gracePeriodDays = 0
  status             SubscriptionStatus @default(ACTIVE)

  // Notification dedup flags — reset on renewal
  reminderSent       Boolean            @default(false)
  expiredNotifSent   Boolean            @default(false)
  suspendedNotifSent Boolean            @default(false)

  // Immutable snapshot of plan rules at subscription creation time
  planSnapshot       Json

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id])
  plan      Plan      @relation(fields: [planId], references: [id])
  payments  Payment[]

  @@index([customerId])
  @@index([status, expirationDate])
  @@index([status, gracePeriodEnd])
  @@map("subscriptions")
}

model Payment {
  id             String        @id @default(uuid())
  customerId     String
  subscriptionId String
  amount         Float
  currency       String        @default("USD")
  status         PaymentStatus @default(PENDING)
  externalRef    String?       // Payment gateway transaction ID
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer     Customer     @relation(fields: [customerId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([customerId])
  @@index([subscriptionId])
  @@map("payments")
}

model Notification {
  id         String           @id @default(uuid())
  customerId String
  type       NotificationType
  channel    String           @default("email")
  sentAt     DateTime         @default(now())
  status     String           @default("SENT")
  metadata   Json?

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, type])
  @@map("notifications")
}

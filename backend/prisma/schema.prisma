generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
  TRIAL
}

enum UserRole {
  SUPERADMIN
  ADMIN
  SOPORTE
  CLIENTE
}

enum SessionLimitPolicy {
  BLOCK_NEW
  REPLACE_OLDEST
}

enum RegistrationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChannelStatus {
  ACTIVE
  SCHEDULED
  MAINTENANCE
  INACTIVE
}

enum StreamProtocol {
  HLS
  DASH
  HLS_DASH
}

enum ChannelHealthStatus {
  HEALTHY
  DEGRADED
  OFFLINE
  MAINTENANCE
}

// ─── Models ──────────────────────────────────────────────

model CmsRole {
  id          String   @id @default(uuid())
  key         UserRole @unique
  permissions String[] @default([])
  updatedAt   DateTime @updatedAt

  @@map("cms_roles")
}

model Customer {
  id                 String     @id @default(uuid())
  nombre             String
  firstName          String?
  lastName           String?
  email              String?    @unique
  ispEmail           String?
  telefono           String?
  idNumber           String?    @unique // Cédula de identidad
  address            String?    // Dirección
  passwordHash       String?
  role               UserRole   @default(CLIENTE)
  status             UserStatus @default(PENDING)
  mustChangePassword Boolean    @default(false)
  mfaEnabled         Boolean    @default(false)
  isLocked           Boolean    @default(false)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  isCmsUser          Boolean    @default(false)
  isSubscriber       Boolean    @default(true)
  isAccountActivated Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  contracts       Contract[]
  sessions        Session[]
  activationCodes ActivationCode[]

  @@map("customers")
}

model Contract {
  id                  String             @id @default(uuid())
  customerId          String
  contractNumber      String             @unique @db.VarChar(20)
  planName            String             @default("LUKI PLAY")
  planId              String?
  ispPlanName         String?
  maxDevices          Int                @default(2)
  maxConcurrentStreams Int               @default(1)
  sessionDurationDays Int                @default(30)
  sessionLimitPolicy  SessionLimitPolicy @default(BLOCK_NEW)
  fechaInicio         DateTime?
  fechaFin            DateTime?
  lastSyncedAt        DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  customer        Customer         @relation(fields: [customerId], references: [id])
  sessions        Session[]
  viewingProfiles ViewingProfile[]
  devices         Device[]

  @@index([customerId])
  @@map("contracts")
}

model ViewingProfile {
  id                     String   @id @default(uuid())
  contractId             String
  displayName            String
  avatarUrl              String?
  preferredLang          String   @default("es")
  parentalControlEnabled Boolean  @default(false)
  parentalControlPin     String?
  contentPreferences     Json     @default("{}")
  isDefault              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@map("viewing_profiles")
}

model Session {
  id           String    @id @default(uuid())
  contractId   String?
  customerId   String?
  deviceId     String
  audience     String    @default("app")
  refreshToken String?   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  contract Contract? @relation(fields: [contractId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([contractId])
  @@index([customerId])
  @@map("sessions")
}

model Device {
  id                String    @id @default(uuid())
  contractId        String
  deviceName        String?
  deviceType        String?
  deviceFingerprint String    @unique
  isActive          Boolean   @default(true)
  lastUsedAt        DateTime?
  createdAt         DateTime  @default(now())

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@map("devices")
}

model Plan {
  id                  String   @id @default(uuid())
  nombre              String   @default("LUKI PLAY")
  descripcion         String   @default("Streaming incluido con tu servicio de luki Internet")
  grupoUsuarios       String   @default("ISP_BUNDLE")
  precio              Float    @default(0)
  moneda              String   @default("USD")
  duracionDias        Int      @default(30)
  activo              Boolean  @default(true)
  maxDevices          Int      @default(3)
  maxConcurrentStreams Int     @default(2)
  maxProfiles         Int      @default(3)
  videoQuality        String   @default("HD")
  allowDownloads      Boolean  @default(false)
  allowCasting        Boolean  @default(true)
  hasAds              Boolean  @default(true)
  trialDays           Int      @default(0)
  gracePeriodDays     Int      @default(0)
  entitlements        Json     @default("[\"live-tv\", \"vod-basic\", \"sports\"]")
  allowedComponentIds Json     @default("[]")
  allowedCategoryIds  Json     @default("[]")
  allowedChannelIds   Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("plans")
}

model ActivationCode {
  id          String    @id @default(uuid())
  customerId  String
  code        String    // "A1B2C3" — alfanumérico 6 chars, en texto plano (corta vida)
  generatedBy String?   // NULL = autoservicio, userId = generado por soporte CMS
  sentToEmail String?   // Email al que se envió el código (NULL si fue por soporte)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([code])
  @@index([customerId])
  @@map("activation_codes")
}

model RegistrationRequest {
  id          String                    @id @default(uuid())
  nombres     String
  apellidos   String
  idNumber    String
  telefono    String
  email       String?
  direccion   String?
  status      RegistrationRequestStatus @default(PENDING)
  reviewedBy  String?   // ID del usuario CMS que aprobó/rechazó
  reviewedAt  DateTime?
  reviewNotes String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([status])
  @@index([idNumber])
  @@map("registration_requests")
}

model SyncLog {
  id                 String    @id @default(uuid())
  syncType           String
  startedAt          DateTime
  completedAt        DateTime?
  customersCreated   Int       @default(0)
  contractsCreated   Int       @default(0)
  contractsUpdated   Int       @default(0)
  contractsSuspended Int       @default(0)
  errors             Int       @default(0)
  errorDetails       Json?
  createdAt          DateTime  @default(now())

  @@map("sync_log")
}

model Category {
  id            String    @id @default(uuid())
  nombre        String    @unique
  slug          String?   @unique
  descripcion   String    @default("")
  icono         String    @default("")
  accentColor   String    @default("#FFB800")
  displayOrder  Int       @default(99)
  activo        Boolean   @default(true)
  esContenidoAdulto Boolean @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  channels            Channel[]
  channelCategories   ChannelCategory[]
  componentCategories ComponentCategory[]

  @@index([activo])
  @@index([displayOrder])
  @@map("categories")
}

model ChannelCategory {
  channelId  String
  categoryId String
  assignedAt DateTime @default(now())

  channel  Channel  @relation(fields: [channelId],  references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([channelId, categoryId])
  @@index([channelId])
  @@index([categoryId])
  @@map("channel_categories")
}

model Channel {
  id                      String              @id @default(uuid())
  nombre                  String              @unique
  slug                    String              @unique

  // Stream URLs
  streamUrl               String
  backupUrl               String?

  // Metadata
  logoUrl                 String?
  categoryId              String
  category                Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  epgSourceId             String?

  // Status & Status Management
  status                  ChannelStatus       @default(ACTIVE)
  isLive                  Boolean             @default(false)
  healthStatus            ChannelHealthStatus @default(OFFLINE)
  uptimePercent           Float               @default(0)
  lastHealthCheckAt       DateTime?

  // Stream Configuration
  streamProtocol          StreamProtocol      @default(HLS)
  resolution              String              @default("1080p")
  bitrateKbps             Int                 @default(5000)
  isDrmProtected          Boolean             @default(false)

  // Geographic & Access Control
  geoRestriction          String?
  sortOrder               Int                 @default(99)
  planIds                 String[]            @default([])
  requiereControlParental Boolean             @default(false)

  // Analytics & Monitoring
  viewerCount             Int                 @default(0)

  // Audit
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  deletedAt               DateTime?

  channelCategories ChannelCategory[]

  @@index([categoryId])
  @@index([status])
  @@index([isLive])
  @@map("channels")
}

model Component {
  id          String   @id
  nombre      String   @unique
  descripcion String   @default("")
  icono       String   @default("")
  tipo        String
  activo      Boolean  @default(true)
  orden       Int      @default(99)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  componentCategories ComponentCategory[]

  @@index([activo])
  @@index([orden])
  @@map("components")
}

model ComponentCategory {
  componentId String
  categoryId  String
  assignedAt  DateTime @default(now())

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId],  references: [id], onDelete: Cascade)

  @@id([componentId, categoryId])
  @@index([componentId])
  @@index([categoryId])
  @@map("component_categories")
}

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://lukiplay_admin:dev_password_2026@localhost:5432/lukiplay_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT — Two separate secrets: subscriber (app) and admin (CMS)
SUBSCRIBER_JWT_SECRET=change-me-in-production
ADMIN_JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# Security
BCRYPT_SALT_ROUNDS=12

# Feature flags
USE_MOCK_API=false

# ISP sync
SYNC_CRON_SCHEDULE=0 */6 * * *

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=20